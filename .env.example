# Required — 32+ character key for encrypting IMAP/SMTP credentials at rest
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# CORS origins (optional — only needed if deploying client separately from the API)
# DOMAINS=https://courrier.yourdomain.com

# OIDC (optional — enable to use Authentik or any OpenID Connect provider)
# OIDC_ISSUER=https://authentik.yourdomain.com/application/o/courrier/
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URL=https://courrier.yourdomain.com/auth/oidc/callback
# OIDC_SUCCESS_URL=https://courrier.yourdomain.com

# Required — PostgreSQL credentials
POSTGRES_USER=
POSTGRES_PASSWORD=
# POSTGRES_DB=courrier

# Optional — override only for non-Docker setups (docker-compose builds it automatically)
# DATABASE_URL=postgresql://user:pass@localhost:5432/courrier?sslmode=disable

# Override defaults only if needed
# PORT=4000
# LOG_LEVEL=info
